mixed-port: 7890
allow-lan: false
mode: rule
log-level: info
ipv6: true

proxies:
  - name: "my-hy2-ip"
    type: hysteria2
    server: 1.2.3.4
    port: 443
    password: replace-with-server-password
    obfs: salamander
    obfs-password: replace-with-obfs-password
    sni: 1.2.3.4
    alpn:
      - h3
    skip-cert-verify: true
    up: "50 Mbps"
    down: "200 Mbps"

proxy-groups:
  - name: "PROXY"
    type: select
    proxies:
      - my-hy2-ip
      - DIRECT

rules:
  - GEOIP,CN,DIRECT
  - MATCH,PROXY
