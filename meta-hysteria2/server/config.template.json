{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "name": "clash-meta",
          "password": "replace-with-strong-password"
        }
      ],
      "obfs": {
        "type": "salamander",
        "password": "replace-with-strong-obfs-password"
      },
      "ignore_client_bandwidth": false,
      "tls": {
        "enabled": true,
        "server_name": "your-domain.example.com",
        "alpn": [
          "h3"
        ],
        "certificate_path": "/etc/letsencrypt/live/your-domain.example.com/fullchain.pem",
        "key_path": "/etc/letsencrypt/live/your-domain.example.com/privkey.pem"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "outbound": "direct"
      }
    ],
    "final": "direct"
  }
}
